# Orbit Axis — LOCAL development template (Update 4.0.2)
#
# Copy to .env.local ONLY if you want these values loaded automatically:
#   cp .env.local.example .env.local
#
# You usually do not need to. `npm run dev:local` already pins Orbit to the
# local Supabase stack using the port in the tracked supabase/config.toml, so
# local development is safe without editing any env file.
#
# Placeholders only. Never commit a real key.

ORBIT_ENVIRONMENT=local

# Local Supabase (started by `supabase start`). Orbit uses the 553xx range
# because another project occupies the standard 543xx range.
SUPABASE_URL=http://127.0.0.1:55321
# The published Supabase local demo anon key. Identical on every machine and
# only valid against a local stack — it is not a secret.
SUPABASE_ANON_KEY=<local anon key printed by: supabase start>

# Never set a service-role key for ordinary local development. It bypasses
# row-level security. `npm run dev:local` deliberately unsets it.
# SUPABASE_SERVICE_ROLE_KEY=

# Optional local language model. Ask Orbit works fully without it.
ORBIT_OLLAMA_BASE_URL=http://127.0.0.1:11434
ORBIT_LOCAL_MODEL=<installed model name, e.g. qwen3:14b>
