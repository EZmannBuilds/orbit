# Orbit Axis — PREVIEW template (Update 4.0.3)
#
# Placeholders only. Real Preview values belong in the Vercel project's
# Environment Variables, scoped to the Preview environment — never in a file in
# this repository.
#
# Read docs/deployment/preview-environment.md before using this.
#
# The single most important rule: Preview must NOT point at the production
# Supabase project. Orbit refuses to start in preview mode unless the project
# reference has been explicitly approved as disposable, because a Preview
# deployment is a place where data gets broken on purpose.

# Vercel sets VERCEL=1 and VERCEL_ENV=preview automatically, and Orbit maps
# VERCEL_ENV=preview to its own "preview" environment. Setting this explicitly
# is optional but makes the intent visible in the dashboard.
ORBIT_ENVIRONMENT=preview

# ── The approved disposable Supabase project ────────────────────────────────
# A SEPARATE Supabase project from production. Create it once, apply the
# migrations to it, and treat its data as throwaway.
SUPABASE_URL=https://<preview-project-ref>.supabase.co

# Browser-safe. Row-level security is what protects the data, not this key.
SUPABASE_ANON_KEY=<preview anon key>

# Orbit will not accept a hosted project for Preview until it is named here
# (or added to APPROVED_PREVIEW_PROJECT_REFS in lib/env/known-targets.js).
# This is the deliberate speed bump that stops Preview from quietly running
# against production. Comma-separated if there is more than one.
ORBIT_PREVIEW_PROJECT_REFS=<preview-project-ref>

# ── Never set on a deployment ───────────────────────────────────────────────
# The service-role key bypasses row-level security. Orbit's request paths use
# the signed-in user's own token instead, so a deployment does not need it.
# SUPABASE_SERVICE_ROLE_KEY=

# ── Language model ──────────────────────────────────────────────────────────
# Ollama runs on the owner's own computer and is unreachable from Vercel.
# Orbit already disables it for any deployment, before any network call is
# attempted; this only makes the intent explicit in the dashboard.
ORBIT_ASK_USE_MODEL=false

# ── Optional ────────────────────────────────────────────────────────────────
# Birthplace search. Without it, birthplace lookup returns a clear error and
# the rest of Orbit still works.
# GEOAPIFY_API_KEY=<geoapify key>
