{
  "name": "orbit",
  "version": "1.0.0",
  "description": "Orbit \u2014 standalone astrology app and API.",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "dev:local": "node scripts/dev-local.js",
    "env:check": "node scripts/env-check.js",
    "env:check:production": "node scripts/env-check.js --production",
    "lint": "node --check server.js && node --check api/*.js && node --check lib/*.js && node --check lib/auth/*.js && node --check lib/env/*.js && node --check lib/server/*.js && node --check lib/deploy/*.js && node --check lib/api/*.js && node --check lib/api/v1/*.js && node --check lib/api/v1/*/*.js && node --check lib/local-llm/*.js && node --check lib/astro/*.js && node --check lib/astro/runtime/*.js && node --check lib/charts/*.js && node --check lib/fortune/*.js && node --check lib/ask-orbit/*.js && node --check lib/locations/*.js && node --check public/app.js && node --check public/moon-phase.js && node --check public/startup-state.js && node --check scripts/*.js",
    "typecheck": "npm run lint",
    "pretest": "node scripts/test-guard.js",
    "test": "node --test",
    "test:local": "node scripts/test-local.js",
    "build": "node scripts/build.js",
    "deploy:check": "node scripts/deploy-check.js",
    "orbit:runtime:check": "node scripts/runtime-check.js",
    "supabase:start:orbit": "supabase start",
    "supabase:status:orbit": "supabase status",
    "supabase:stop:orbit": "supabase stop",
    "supabase:migrate:local": "node scripts/migrate-local.js",
    "orbit:llm:status": "node scripts/local-llm.js status",
    "orbit:llm:models": "node scripts/local-llm.js models",
    "orbit:llm:test": "node scripts/local-llm.js test",
    "orbit:vault:search": "node scripts/local-llm.js search",
    "orbit:vault:propose": "node scripts/local-llm.js propose",
    "orbit:vault:proposals": "node scripts/local-llm.js proposals",
    "orbit:vault:apply": "node scripts/local-llm.js apply",
    "orbit:vault:scan": "node scripts/vault-sync.js scan",
    "orbit:vault:validate": "node scripts/vault-sync.js validate",
    "orbit:vault:status": "node scripts/vault-sync.js status",
    "orbit:vault:sync": "node scripts/vault-sync.js sync",
    "orbit:vault:push": "node scripts/vault-sync.js sync --push",
    "orbit:core:smoke": "node scripts/core-smoke.js",
    "engine:sync": "node scripts/engine-sync.js",
    "engine:check": "node scripts/engine-sync.js --check"
  },
  "dependencies": {
    "luxon": "^3.7.2",
    "tz-lookup": "^6.1.25",
    "@ezmannbuilds/orbit-axis-engine": "file:vendor/orbit-axis-engine"
  },
  "engines": {
    "node": "22.x"
  }
}
