# Orbit configuration — copy to .env.local and adjust as needed.
# Every value here is OPTIONAL. Orbit runs with zero configuration; these
# only override defaults. No secrets or API keys are required.

# HTTP port the Orbit server listens on.
PORT=3001

# ── Local LLM (Ollama only) ─────────────────────────────────────────────────
# Optional. Orbit runs without Ollama; local intelligence falls back to
# deterministic retrieval when Ollama is unavailable.
ORBIT_LOCAL_LLM_ENABLED=true
ORBIT_LOCAL_LLM_PROVIDER=ollama
ORBIT_OLLAMA_BASE_URL=http://127.0.0.1:11434
ORBIT_LOCAL_MODEL=
ORBIT_LOCAL_EMBEDDING_MODEL=
ORBIT_LOCAL_LLM_CONTEXT_LENGTH=8192
ORBIT_LOCAL_LLM_TEMPERATURE=0.2
ORBIT_LOCAL_LLM_TIMEOUT_MS=180000
ORBIT_LOCAL_LLM_MAX_OUTPUT_TOKENS=3000
ORBIT_LOCAL_LLM_MAX_NOTE_CHARS=80000

# Canonical Obsidian vault. Project/business documentation lives here.
# Absolute path to your Obsidian vault, if you keep one. Local to your
# machine; only the vault-sync tooling reads it.
ORBIT_VAULT_PATH=

# ── Supabase ────────────────────────────────────────────────────────────────
# Copy to .env.local and fill in. Placeholders only here — never commit real
# keys. See docs/supabase-setup.md.

# Project URL and the client-safe key are used by frontend + the vault sync
# tool's read/write-as-user operations.
SUPABASE_URL=
# Prefer the modern publishable key (sb_publishable_...). The legacy anon JWT
# also works. Both are safe to ship to the browser.
SUPABASE_ANON_KEY=
# Optional for local CLI/API writes that record user-owned rows with RLS.
# Must match the authenticated SUPABASE_ACCESS_TOKEN user.
SUPABASE_OWNER_ID=

# BACKEND-ONLY. Bypasses Row Level Security. NEVER expose this to the browser,
# never import it into client code, never commit it. Only set it in a server
# environment for privileged jobs (e.g. seeding reference data).
SUPABASE_SERVICE_ROLE_KEY=

# ── Shared-database acknowledgement ─────────────────────────────────────────
# Orbit runs on ONE Supabase project, so local development shares a database
# with production. Orbit refuses to start that way unless this names the project
# explicitly. A boolean would survive being copied into an unrelated checkout
# pointed at a different database; a project reference does not.
#
# Leave this unset to use a local Supabase (`supabase start`) instead.
ORBIT_ACKNOWLEDGE_PRODUCTION_DB=

# Where a password-reset email should send someone. Optional: Orbit derives it
# from the request host when unset. Must also be allow-listed in the Supabase
# dashboard under Authentication -> URL Configuration -> Redirect URLs.
ORBIT_PASSWORD_RESET_URL=

# ── Version-one feature flags ───────────────────────────────────────────────
# Tarot, Learn, and News are built but unfinished, and are hidden from the
# version-one production experience. The implementation is preserved; only
# visibility changes.
#
# Set one to "true" (or "enabled") to work on it locally or in a Vercel
# preview. Anything else — "1", "yes", "on", empty — is off, on purpose.
#
# PRODUCTION IGNORES THESE ENTIRELY. A feature cannot be switched on for real
# users by configuration; that takes a code change and a release, which is the
# right amount of ceremony for "show this to everybody".
ORBIT_FEATURE_TAROT=
ORBIT_FEATURE_LEARN=
ORBIT_FEATURE_NEWS=

# ── Legal and contact facts ─────────────────────────────────────────────────
# The public pages (/privacy, /terms, /support, /source, /account-deletion)
# read these. They are OWNER DECISIONS, not engineering ones, so Orbit refuses
# to invent them: any value left unset renders as a visible "not yet published"
# state rather than a plausible placeholder. A fake support address is a promise
# the product cannot keep.
#
# All four are required before Orbit Axis is offered publicly.
ORBIT_LEGAL_ENTITY=
ORBIT_SUPPORT_EMAIL=
ORBIT_GOVERNING_JURISDICTION=
ORBIT_MINIMUM_AGE=

# Public repository URLs, once both are published. Validated: https only, and
# only on a known code host. Anything else is rejected and the source page falls
# back to "publication pending" — an unvalidated URL here is a destination the
# application would be vouching for.
ORBIT_SOURCE_APP_URL=
ORBIT_SOURCE_ENGINE_URL=
