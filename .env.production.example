# Orbit Axis — PRODUCTION template (Update 4.0.2)
#
# Placeholders only. Real production values belong in the deployment platform's
# environment settings, never in a file in this repository.
#
# Orbit refuses to start in production mode with a localhost database, with no
# anon key, or with an unreadable Supabase URL.

ORBIT_ENVIRONMENT=production

# The hosted Supabase project.
SUPABASE_URL=https://<project-ref>.supabase.co
# Browser-safe. Row-level security is what protects the data.
SUPABASE_ANON_KEY=<hosted anon key>

# Server-only. Bypasses row-level security — never expose it to a browser and
# only set it if a server operation genuinely requires it.
# SUPABASE_SERVICE_ROLE_KEY=<hosted service-role key>

# Ask Orbit uses its built-in deterministic formatter in production.
# A local model is never reachable from a deployment.
ORBIT_ASK_USE_MODEL=false
