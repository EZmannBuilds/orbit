# ── Dependencies ──
node_modules/

# ── Secrets & env (never commit) ──
.env
.env.local
.env.*.local
*.env
# .env.example (placeholders only) IS tracked and is not matched above.

# ── Keys / tokens / credentials ──
*.pem
*.key
*.p12
secrets/
credentials/
tokens/

# ── Logs / cache / build ──
*.log
npm-debug.log*
.cache/
.orbit/
supabase/.temp/
dist/
build/

# ── OS cruft ──
.DS_Store
._*

# Local Supabase CLI state
supabase/.branches/

# ── Vercel ──
# `vercel link` / `vercel build` write project ids, org ids, and pulled
# environment values here. None of it belongs in the repository.
.vercel/
